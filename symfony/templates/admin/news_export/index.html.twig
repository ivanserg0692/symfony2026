{% extends '@EasyAdmin/crud/index.html.twig' %}

{% block main %}
    {{ parent() }}

    <div class="modal fade" id="news-export-modal" tabindex="-1" aria-labelledby="news-export-modal-title" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content" data-news-export-modal-content data-news-export-csrf-token="{{ csrf_token('start_news_export') }}">
                <div class="modal-body">
                    <div class="text-muted">Loading...</div>
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block configured_javascripts %}
    {{ parent() }}
    {{ importmap('admin-news-export') }}
{% endblock %}

{% block configured_stylesheets %}
    {{ parent() }}
    <style>
        .news-export-pagination {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        #news-export-modal form {
            display: flex;
            flex-direction: column;
            min-height: 0;
            max-height: calc(100vh - 3.5rem);
        }

        #news-export-modal .modal-body {
            overflow: auto;
        }
    </style>
{% endblock %}
